{
    "family": "franquicias-api-task",
    "executionRoleArn": "arn:aws:iam::695646686656:role/franquicias-api-task-exec-role",
    "networkMode": "awsvpc",
    "cpu": "256",
    "memory": "512",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "containerDefinitions": [
        {
            "name": "franquicias-api-container",
            "image": "695646686656.dkr.ecr.us-east-1.amazonaws.com/franquicias-api@sha256:3518795f1f33d98708a0dca1f702e848addd29e50a429b358c3148a2a23d3824",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "SERVER_PORT",
                    "value": "8080"
                },
                {
                    "name": "MONGODB_URI",
                    "value": "mongodb+srv://<user>:<password>@cluster.mongodb.net/franquicias?retryWrites=true&w=majority&appName=Cluster0"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/franquicias-api",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ]
}
