            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}/stock", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}", "sucursales", "{{sucursal_id}}", "productos", "{{producto_id}}", "stock"]}
          }
        },
        {
          "name": "Actualizar nombre de Producto",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"nombre\": \"Big Mac Actualizado\"\n}"},
            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}/nombre", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}", "sucursales", "{{sucursal_id}}", "productos", "{{producto_id}}", "nombre"]}
          }
        },
        {
          "name": "Eliminar Producto",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}", "sucursales", "{{sucursal_id}}", "productos", "{{producto_id}}"]}
          }
        }
      ]
    },
    {
      "name": "Reportes",
      "item": [
        {
          "name": "Productos con Máximo Stock por Sucursal",
          "request": {
            "method": "GET",
            "description": "Obtiene por franquicia el producto con mayor stock en cada sucursal.",
            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}/productos-max-stock", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}", "productos-max-stock"]}
          }
        }
