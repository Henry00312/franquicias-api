{
  "info": {
    "name": "API Gestión Franquicias",
    "description": "Colección de requests para probar la API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Franquicias",
      "item": [
        {
          "name": "Crear Franquicia",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"nombre\": \"Franquicia McDonald's\"\n}"},
            "url": {"raw": "http://localhost:8080/api/franquicias", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias"]}
          }
        },
        {
          "name": "Obtener todas las Franquicias",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/franquicias", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias"]}
          }
        },
        {
          "name": "Obtener Franquicia por ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}"]}
          }
        },
        {
          "name": "Actualizar nombre de Franquicia",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"nombre\": \"Franquicia McDonald's - Actualizada\"\n}"},
            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}/nombre", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}", "nombre"]}
          }
        },
        {
          "name": "Eliminar Franquicia",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8080/api/franquicias/{{franquicia_id}}", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "franquicias", "{{franquicia_id}}"]}
          }
        }
      ]
    },
    {
