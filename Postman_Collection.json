{
  "info": {
    "name": "API Gestion Franquicias",
    "description": "Coleccion de requests para probar la API en AWS o local usando variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Sistema",
      "item": [
        {
          "name": "Estado API",
          "request": {
            "method": "GET",
            "url": "{{base_url}}"
          }
        }
      ]
    },
    {
      "name": "Franquicias",
      "item": [
        {
          "name": "Crear Franquicia",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Franquicia McDonald's\"\n}"
            },
            "url": "{{base_url}}/franquicias"
          }
        },
        {
          "name": "Crear Franquicia Duplicada (409)",
          "request": {
            "method": "POST",
            "description": "Ejecuta esta request despues de crear una franquicia con el mismo nombre para validar respuesta 409 con mensaje.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Franquicia McDonald's\"\n}"
            },
            "url": "{{base_url}}/franquicias"
          }
        },
        {
          "name": "Obtener todas las Franquicias",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/franquicias"
          }
        },
        {
          "name": "Obtener Franquicia por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}"
          }
        },
        {
          "name": "Actualizar nombre de Franquicia",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Franquicia McDonald's - Actualizada\"\n}"
            },
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/nombre"
          }
        },
        {
          "name": "Eliminar Franquicia",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}"
          }
        }
      ]
    },
    {
      "name": "Sucursales",
      "item": [
        {
          "name": "Crear Sucursal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Sucursal Centro\"\n}"
            },
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales"
          }
        },
        {
          "name": "Obtener Sucursales de Franquicia",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales"
          }
        },
        {
          "name": "Obtener Sucursal por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}"
          }
        },
        {
          "name": "Actualizar nombre de Sucursal",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Sucursal Norte - Actualizada\"\n}"
            },
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/nombre"
          }
        },
        {
          "name": "Eliminar Sucursal",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}"
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Crear Producto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Big Mac\",\n  \"stock\": 100\n}"
            },
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos"
          }
        },
        {
          "name": "Obtener Productos de Sucursal",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos"
          }
        },
        {
          "name": "Obtener Producto por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}"
          }
        },
        {
          "name": "Actualizar Stock de Producto",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stock\": 50\n}"
            },
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}/stock"
          }
        },
        {
          "name": "Actualizar nombre de Producto",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Big Mac Actualizado\"\n}"
            },
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}/nombre"
          }
        },
        {
          "name": "Eliminar Producto",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/sucursales/{{sucursal_id}}/productos/{{producto_id}}"
          }
        }
      ]
    },
    {
      "name": "Reportes",
      "item": [
        {
          "name": "Productos con Maximo Stock por Sucursal",
          "request": {
            "method": "GET",
            "description": "Obtiene por franquicia el producto con mayor stock en cada sucursal.",
            "url": "{{base_url}}/franquicias/{{franquicia_id}}/productos-max-stock"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "{{aws_base_url}}"
    },
    {
      "key": "aws_base_url",
      "value": "http://franquicias-api-alb-1260749581.us-east-1.elb.amazonaws.com/api"
    },
    {
      "key": "local_base_url",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "franquicia_id",
      "value": "YOUR_FRANQUICIA_ID"
    },
    {
      "key": "sucursal_id",
      "value": "YOUR_SUCURSAL_ID"
    },
    {
      "key": "producto_id",
      "value": "YOUR_PRODUCTO_ID"
    }
  ]
}